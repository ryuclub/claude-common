{
  "permissions": {
    "allow": [
      "Read(./**)",
      "Read(../**)",
      "Bash(git:*)",
      "Bash(go fmt:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)"
    ],
    "additionalDirectories": [
      "./internal",
      "./cmd",
      "./.claude",
      "./.claude-local",
      "./design"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .claude-local/hooks/auto-load.sh",
        "async": true,
        "statusMessage": "Initializing project configuration..."
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "claude-api@anthropic-agent-skills": true,
    "generic-jira-tools@claude-generic-skills": true,
    "generic-git-tools@claude-generic-skills": true
  }
}
